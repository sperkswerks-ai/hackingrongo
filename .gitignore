# Data — tracked separately (use zip for Colab, DVC or similar for versioning)
data/*
!data/README.md

# Packaged data bundles (36+ MB) must never land in git history
hackingrongo_data*.zip
# Transient transfer bundles, checkpoint archives, and per-run output snapshots
# (created during Azure/Colab round-trips — must never land in git history)
azure_rerun_bundle*
hackingrongo_checkpoints*.zip
outputs_run*/
*.json.bak

# CI fixtures are small and committed so CI runs without the full corpus.
!tests/ci-fixtures/
# Static sign catalog — committed so CI and Colab run without the full corpus zip.
!data/catalog/
!data/catalog/**
# Small reference image sets committed directly so Kaggle git clone has them
# without needing network fetches (fetch_indus_glyphs.py, render_linearb_glyphs.py).
!data/glyphs/
data/glyphs/*
!data/glyphs/indus/
!data/glyphs/indus/**
!data/glyphs/linear_b/
!data/glyphs/linear_b/**

# Training outputs and model checkpoints
outputs/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
pip-wheel-metadata/

# Environments
.env
.venv
env/
venv/
.conda/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDEs
.idea/
.vscode/settings.json
*.suo
*.user

# MLflow / experiment tracking
mlruns/
mlartifacts/
